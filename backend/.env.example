# --- Database ---
# Local dev with Postgres running on your machine:
DATABASE_URL=postgresql://studysync:studysync@localhost:5432/studysync

# --- Auth ---
# Generate a real one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days

# --- AI provider (added in chunk 3; optional — app runs without it) ---
# AI_PROVIDER=gemini            # "openai" | "gemini" | "none"
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# --- CORS ---
# Comma-separated list of frontend origins allowed to call the API
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
